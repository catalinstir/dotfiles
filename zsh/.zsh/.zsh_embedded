# ── Embedded helpers — add to ~/.zsh/.zsh_functions ──────────────────────────

# Set J-Link device for the current shell session (all other functions read this)
embdev() {
    if [[ -z "$1" ]]; then
        echo "Usage: embdev <device>"
        echo "  KL25Z  → embdev MKL25Z128xxx4"
        echo "  FMUK66 → embdev MK66FN2M0xxx18"
        echo "Current: ${JLINK_DEVICE:-(not set)}"
        return
    fi
    export JLINK_DEVICE="$1"
    echo "JLINK_DEVICE=$JLINK_DEVICE"
}

# Flash .elf via J-Link (finds Debug/*.elf automatically)
embflash() {
    local device="${JLINK_DEVICE:-MKL25Z128xxx4}"
    local elf="${1:-$(find . -name '*.elf' -path '*/Debug/*' 2>/dev/null | head -1)}"

    if [[ -z "$elf" ]]; then
        echo "No .elf found in Debug/. Pass path explicitly: embflash path/to/file.elf"
        return 1
    fi

    echo "Flashing: $elf"
    echo "Device:   $device"

    local script=$(mktemp /tmp/jlink_flash.XXXXXX.jlink)
    printf "r\nh\nloadfile %s\nr\ng\nqc\n" "$elf" > "$script"
    JLinkExe -device "$device" -if SWD -speed 4000 -autoconnect 1 -CommanderScript "$script"
    rm -f "$script"
}

# Start J-Link GDB server (run in a dedicated tmux pane, leave it running)
# Then in another pane: arm-none-eabi-gdb Debug/project.elf
#                       (gdb) target remote :2331
#                       (gdb) monitor reset halt
#                       (gdb) load
#                       (gdb) continue
embgdb() {
    local device="${JLINK_DEVICE:-MKL25Z128xxx4}"
    echo "J-Link GDB server | device: $device | port: 2331"
    echo "In another pane:  arm-none-eabi-gdb Debug/<name>.elf"
    echo "  (gdb) target remote :2331"
    echo "  (gdb) monitor reset halt"
    echo "  (gdb) load"
    echo "  (gdb) continue"
    echo ""
    JLinkGDBServerCLExe \
        -select USB \
        -device "$device" \
        -if SWD \
        -speed 4000 \
        -port 2331 \
        -noir \
        -noLocalhostOnly
}

# Full debug session in one command:
# - starts J-Link GDB server in the background
# - launches arm-none-eabi-gdb connected to it
# - loads the .elf, resets, and halts at main
# Run this in a tmux pane. Kill with Ctrl+C or 'quit' in GDB.
embdebug() {
    local device="${JLINK_DEVICE:-MKL25Z128xxx4}"
    local elf="${1:-$(find . -name '*.elf' -path '*/Debug/*' 2>/dev/null | head -1)}"

    if [[ -z "$elf" ]]; then
        echo "No .elf found in Debug/. Pass path explicitly: embdebug path/to/file.elf"
        return 1
    fi

    echo "Device: $device"
    echo "ELF:    $elf"
    echo ""

    # Start GDB server in background
    JLinkGDBServerCLExe \
        -select USB \
        -device "$device" \
        -if SWD \
        -speed 4000 \
        -port 2331 \
        -noir \
        -noLocalhostOnly \
        -silent &
    local gdb_server_pid=$!

    # Give it a moment to come up
    sleep 1

    # Launch GDB and connect
    arm-none-eabi-gdb "$elf" \
        -ex "target remote :2331" \
        -ex "monitor reset halt" \
        -ex "load" \
        -ex "monitor reset halt" \
        -ex "break main" \
        -ex "continue"

    # Clean up GDB server when GDB exits
    kill "$gdb_server_pid" 2>/dev/null
}

# Open serial monitor (run in a dedicated tmux pane, exit with Ctrl+A Ctrl+X)
embserial() {
    local port="${SERIAL_PORT:-/dev/ttyACM0}"
    local baud="${SERIAL_BAUD:-115200}"
    [[ -n "$1" ]] && port="$1"
    [[ -n "$2" ]] && baud="$2"

    if ! command -v picocom &>/dev/null; then
        echo "Install picocom: sudo apt install picocom"
        return 1
    fi

    echo "Serial: $port @ $baud | Exit: Ctrl+A, Ctrl+X"
    picocom -b "$baud" "$port" --omap crcrlf
}

# List connected debuggers and serial ports
embdevices() {
    echo "=== USB (debuggers) ==="
    lsusb | grep -i -E "segger|nxp|pemicro|dap|jlink" || echo "(none)"
    echo ""
    echo "=== Serial ports ==="
    ls /dev/ttyACM* /dev/ttyUSB* 2>/dev/null || echo "(none)"
}
